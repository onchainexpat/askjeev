# === Required ===

# Wallet private key (for signing swaps and transactions on Base)
PRIVATE_KEY=0x...

# Uniswap Trading API key (get at https://developers.uniswap.org/dashboard/)
UNISWAP_API_KEY=

# Bankr LLM Gateway API key (get at https://bankr.bot/api)
BANKR_API_KEY=bk_...

# Venice AI API key (get at https://venice.ai)
VENICE_API_KEY=

# === Optional ===

# Synthesis hackathon API key (from registration)
SYNTH_API_KEY=sk-synth-...

# x402 wallet config (if using x402-wallet-mcp as dependency)
X402_PER_CALL_MAX=5.00
X402_DAILY_CAP=50.00

# Server port for x402 service endpoints
PORT=3402

# Base RPC URL (default: public Base RPC)
BASE_RPC_URL=https://mainnet.base.org

# === Self Agent ID (optional — for Self track) ===
SELF_ENABLED=false
SELF_NETWORK=mainnet
